  LogWorker --> Postgres

  API --> ServiceBus
  ServiceBus --> NotifyWorker
  ServiceBus --> VideoWorker

  NotifyWorker --> Postgres
  VideoWorker --> Blob
  VideoWorker --> Postgres

  API --> Blob
  Blob --> Cloudflare
  Cloudflare --> Guest

  AKS --> Monitor
  AKS --> Logs
  API --> AppInsights
  Ingestion --> AppInsights
  LogWorker --> Logs
  VideoWorker --> Logs
