APP_ENV=local
LOG_LEVEL=INFO

WEB_PORT=3000
API_PORT=8000
INGESTION_API_PORT=8001

# Messaging mode:
# local = file-backed mock queues
# azure = Azure Event Hubs / Azure Service Bus
MESSAGE_MODE=local

# Database:
# sqlite = local demo
# postgres = production Azure PostgreSQL
DATABASE_MODE=sqlite
DATABASE_URL=sqlite:////data/db/venueops.db

# Local mock queue paths used inside containers
DATA_DIR=/data
MOCK_EVENTHUB_QUEUE=/data/queues/device_logs.jsonl
MOCK_SERVICEBUS_QUEUE=/data/queues/jobs.jsonl
AUDIT_LOG_PATH=/data/audit/audit.jsonl

# Azure Event Hubs
EVENTHUB_FULLY_QUALIFIED_NAMESPACE=
EVENTHUB_NAME=device-logs
EVENTHUB_CONSUMER_GROUP=log-processors

# Azure Service Bus
SERVICEBUS_FULLY_QUALIFIED_NAMESPACE=
SERVICEBUS_NOTIFICATION_QUEUE=notification-jobs
SERVICEBUS_VIDEO_QUEUE=video-jobs
SERVICEBUS_DEVICE_COMMAND_QUEUE=device-commands

# Azure observability placeholders
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Real providers would be configured through Azure Key Vault in production
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
